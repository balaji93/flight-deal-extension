{
  "manifest_version": 3,
  "name": "India Flight Deal Finder",
  "version": "1.0.0",
  "description": "Find the best bank offers and flight deals across 12+ Indian booking sites.",
  "permissions": [
    "sidePanel",
    "storage",
    "declarativeNetRequest",
    "scripting"
  ],
  "host_permissions": [
    "https://www.makemytrip.com/*",
    "https://www.easemytrip.com/*",
    "https://www.cleartrip.com/*",
    "https://www.ixigo.com/*",
    "https://www.yatra.com/*",
    "https://www.goibibo.com/*",
    "https://www.goindigo.in/*",
    "https://www.airindia.com/*",
    "https://www.akasaair.com/*",
    "https://www.airindiaexpress.com/*",
    "https://www.spicejet.com/*",
    "https://www.starair.in/*",
    "https://www.skyscanner.co.in/*",
    "https://www.skyscanner.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Deal Finder"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
